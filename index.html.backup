<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quantum Proxy - 量子代理</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700;900&display=swap">

    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="/tailwind.css">

    <!-- Application CSS (extracted from inline styles) -->
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/global.css">
  </head>

  <body>
    <!-- Page transition overlay -->
    <div id="page-transition-overlay">
      <div class="transition-spinner">
        <div class="spinner-ring"></div>
        <div class="spinner-text">正在加载...</div>
      </div>
    </div>

    <!-- React mount points -->
    <div id="root"></div>
    <div id="isp-root" style="display:none;"></div>

    <!-- Quantum Proxy Footer -->
    <footer class="quantum-footer">
      <div class="footer-content">
        <div class="footer-links">
          <a href="/?tab=privacy">Privacy Policy</a>
          <a href="/?tab=terms">Terms of Service</a>
          <a href="/?tab=refund">Refund Policy</a>
        </div>
        <div class="footer-text">
          <div class="footer-copyright">&copy; 2026 Quantum Proxy. All rights reserved.</div>
          <div class="footer-disclaimer">This platform provides data services only and does not constitute investment advice.</div>
        </div>
      </div>
    </footer>

    <!-- Help Center Page -->
    <div id="help-center-page" class="help-center-page">
      <!-- Top navigation (consistent with home page) -->
      <header class="home-header" style="z-index: 10001;">
        <div class="header-content">
          <div class="logo" onclick="window.location.href = window.location.pathname;" style="cursor:pointer;">量子代理</div>
          <button class="hc-back-home-btn" onclick="if(typeof closeHelpCenter==='function'){closeHelpCenter();}else{window.location.href=window.location.pathname;}">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
            <svg class="hc-home-icon" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
            </svg>
            <span>首页</span>
          </button>
          <nav class="nav-menu">
            <div class="dropdown">
              <a href="#" class="dropdown-link" onclick="window.location.href = window.location.pathname; return false;">产品 <span class="arrow"></span></a>
            </div>
            <div class="dropdown">
              <a href="#" class="dropdown-link" onclick="window.location.href = window.location.pathname + '?tab=purchase'; return false;">价格 <span class="arrow"></span></a>
            </div>
            <a href="#" onclick="window.location.href = window.location.pathname + '?tab=solutions'; return false;">解决方案</a>
            <a href="#" class="active" onclick="return false;">帮助中心</a>
            <a href="#" onclick="window.location.href = window.location.pathname + '?tab=api_docs'; return false;">文档</a>
            <div class="dropdown">
              <a href="#" class="dropdown-link" onclick="return false;">商务合作 <span class="arrow"></span></a>
            </div>
          </nav>
          <button class="login-btn" onclick="window.location.href = window.location.pathname;">注册/登录</button>
        </div>
      </header>

      <!-- Search area -->
      <div class="help-search-container">
        <div class="help-search-wrapper">
          <svg class="help-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/>
            <path d="M21 21l-4.35-4.35"/>
          </svg>
          <input type="text" class="help-search-input" id="help-search-input" placeholder="搜索帮助文档、常见问题..." autocomplete="off">
          <button class="help-search-clear" id="help-search-clear" onclick="clearHelpSearch()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="search-results-hint" id="search-results-hint">
          找到 <span class="highlight" id="search-count">0</span> 个相关结果
        </div>
      </div>

      <!-- Main content area -->
      <div class="help-main-content">
        <!-- Left sidebar (TOC) -->
        <aside class="help-sidebar">
          <div class="sidebar-header">
            <a class="hc-sidebar-back" href="javascript:void(0)" onclick="if(typeof closeHelpCenter==='function'){closeHelpCenter();}else{window.location.href=window.location.pathname;}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5"/>
                <path d="M12 19l-7-7 7-7"/>
              </svg>
              <span>返回首页</span>
            </a>
            <h3>目录导航</h3>
          </div>
          <div class="sidebar-content" id="toc-container">
            <!-- TOC will be dynamically generated by JS -->
          </div>
        </aside>

        <!-- Right content area -->
        <main class="help-content-area">
          <div class="content-header">
            <div class="content-breadcrumb" id="content-breadcrumb">
              <span>帮助中心</span>
              <span class="separator">›</span>
              <span class="current">选择一个主题</span>
            </div>
            <div class="content-actions">
              <button class="content-action-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14,2 14,8 20,8"/>
                </svg>
                打印
              </button>
            </div>
          </div>
          <div class="content-body" id="content-body">
            <!-- Default placeholder -->
            <div class="content-placeholder" id="content-placeholder">
              <div class="content-placeholder-icon">📚</div>
              <h4>欢迎来到帮助中心</h4>
              <p>请从左侧目录选择您想要了解的内容，我们将为您提供详细的使用指南和常见问题解答。</p>
            </div>

            <!-- Content display area -->
            <div class="content-display" id="content-display">
              <h2 id="content-title">标题</h2>
              <div class="content-meta">
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  最后更新：<span id="content-date">2026-02-05</span>
                </span>
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                  阅读量：<span id="content-views">--</span>
                </span>
              </div>
              <div class="content-text" id="content-text">
                内容区域（暂留为空白）
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>

    <!-- Vite entry point for dynamic routes -->
    <script type="module" src="/src/main.jsx"></script>

    <!-- Debug script -->
    <script>
      window.addEventListener('load', () => {
        setTimeout(() => {
          console.log('[Debug] Checking root element...');
          const root = document.getElementById('root');
          console.log('[Debug] Root element:', root);
          console.log('[Debug] Root content:', root ? root.innerHTML : 'null');
          console.log('[Debug] Root display:', root ? window.getComputedStyle(root).display : 'null');
        }, 1000);
      });
    </script>

    <!-- Static JavaScript files (legacy from original Vite build) -->
    <script src="/js/videoBackground.js"></script>
    <script src="/js/helpCenter.js"></script>
    <script src="/js/languageSwitcher.js"></script>
    <script src="/js/navigation.js"></script>
    <script src="/js/countryInventory.js"></script>
    <script src="/js/footerCleaner.js"></script>
    <script src="/js/socialInteraction.js"></script>
  </body>
</html>
